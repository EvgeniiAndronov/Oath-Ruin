[gd_scene load_steps=3 format=3 uid="uid://main_menu"]

[ext_resource type="Script" path="res://scripts/ui/main_menu.gd" id="1_main"]

[node name="MainMenu" type="Control"]
script = ExtResource("1_main")
layout_mode="control"
anchors_preset="full_rect"

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode="control"
anchors_preset="full_rect"
size_flags_horizontal="size_flags_horizontal"
size_flags_vertical="size_flags_vertical"

[node name="Title" type="Label" parent="VBoxContainer"]
layout_mode="center_top"
text="⚔️ OATH & RUIN"
horizontal_alignment="center"
add_theme_font_size_override("font_size", 48)

[node name="PlayButton" type="Button" parent="VBoxContainer"]
layout_mode="center_center"
text="Играть"
size_flags_horizontal="size_flags_horizontal"

[node name="SettingsButton" type="Button" parent="VBoxContainer"]
layout_mode="center_center"
text="Настройки"
size_flags_horizontal="size_flags_horizontal"

[node name="QuitButton" type="Button" parent="VBoxContainer"]
layout_mode="center_center"
text="Выход"
size_flags_horizontal="size_flags_horizontal"

[connection signal="pressed" from="VBoxContainer/PlayButton" to="." method="_on_play_pressed"]
[connection signal="pressed" from="VBoxContainer/QuitButton" to="." method="_on_quit_pressed"]
